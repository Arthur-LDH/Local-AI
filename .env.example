# Copiez ce fichier en .env et remplissez les valeurs réelles.
# Ne committez jamais .env dans Git.

# --- Projet ---
# Préfixe utilisé pour nommer les conteneurs (ex: monprojet.ollama, monprojet.litellm)
PROJECT_NAME=local-ai

# --- Ollama ---
OLLAMA_VERSION=0.30.7
# Durée de maintien des modèles en mémoire après la dernière requête.
# -1 = illimité (jamais déchargé), 0 = déchargé immédiatement, sinon durée en secondes/minutes (ex: "5m").
OLLAMA_KEEP_ALIVE=-1
# Taille du contexte (en tokens) pour les modèles servis par Ollama.
OLLAMA_CONTEXT_LENGTH=32768

# --- LiteLLM ---
LITELLM_VERSION=v1.88.1
# Port exposé sur l'hôte pour l'API LiteLLM (ex: si utilisé via Cloudflare Tunnel
# ou en accès direct). Le port interne au conteneur reste 4000.
LITELLM_PORT=4000

# --- Base de données PostgreSQL externe ---
# Format : postgresql://user:password@host:5432/dbname
# Les clés API cloud (Anthropic, Gemini, etc.) sont gérées via
# l'UI LiteLLM et stockées chiffrées en base — plus besoin de les mettre ici.
DATABASE_URL=postgresql://litellm:changeme@db-host:5432/litellm

# --- Clé maître LiteLLM ---
# Clé bootstrap : doit exister avant le démarrage, ne peut pas être générée
# automatiquement (c'est elle qui protège l'accès à tout le reste, y compris la DB).
# Générez-la une fois et gardez-la dans .env :
#   openssl rand -hex 32
LITELLM_MASTER_KEY=change_me
